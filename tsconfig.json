{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Node 16 + Project References",
  "_version": "16.0.0",

  "compilerOptions": {
    "lib": ["es2020"],
    "target": "es2020",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "types": ["@types/node"],
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmitOnError": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo/root.tsbuildinfo"
  },
  "include": ["src/index.ts"],
  "exclude": ["dist", "node_modules"],
  "references": [
    {
      "path": "./src/shared"
    },
    {
      "path": "./src/client"
    },
    {
      "path": "./src/server"
    }
  ]
}
